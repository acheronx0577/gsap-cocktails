# Resend — set in the Convex dashboard for real email delivery.
# RESEND_API_KEY=
CONTACT_EMAIL=
# CONTACT_FROM=Portfolio Contact <onboarding@resend.dev>

# Optional override for client IP detection on /api/contact.
# On Vercel, proxy headers are trusted automatically (VERCEL=1).
# Set to "false" locally if you need fingerprint-based keys instead of IP.
TRUST_PROXY_HEADERS=

# Shared secret for signed local contact rate-limit cookies.
CONTACT_RATE_LIMIT_SECRET=

# Convex (written by `npx convex dev --once`; use cloud URLs after `npx convex login`)
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=
# HTTP actions base (.convex.site in cloud). Local dev uses port 3211, not 3210.
# Use NEXT_PUBLIC_CONVEX_SITE_URL locally — do not set CONVEX_SITE_URL in the same file
# (Convex CLI treats both as site URL vars and will not auto-update).
NEXT_PUBLIC_CONVEX_SITE_URL=
# Server-side only (Vercel production). Omit locally if NEXT_PUBLIC_CONVEX_SITE_URL is set.
CONVEX_SITE_URL=

# Shared secret for Next.js -> Convex HTTP contact ingress.
# Must match the same variable in the Convex dashboard (dev + prod deployments).
CONTACT_INGRESS_SECRET=

# Convex dashboard only — salt used before storing contact rate-limit IP hashes.
# Required for contact rate limiting in both local `convex dev` and cloud deployments.
# RATE_LIMIT_SALT=

# Vercel project settings (Production + Preview):
# - CONVEX_SITE_URL = https://<deployment>.convex.site (HTTP actions — not .convex.cloud)
# - Or set NEXT_PUBLIC_CONVEX_URL only; the contact API derives the .convex.site host
# - CONTACT_INGRESS_SECRET = same value as in Convex dashboard
# - CONTACT_RATE_LIMIT_SECRET = random string (signed rate-limit cookies)
# - TRUST_PROXY_HEADERS is optional on Vercel (auto-detected via VERCEL=1)
