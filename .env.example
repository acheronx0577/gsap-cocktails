# Resend — set in the Convex dashboard for real email delivery.
# RESEND_API_KEY=
CONTACT_EMAIL=
# CONTACT_FROM=Portfolio Contact <onboarding@resend.dev>

# Trust x-forwarded-for / x-real-ip only behind Vercel or another stripping proxy.
TRUST_PROXY_HEADERS=

# Shared secret for signed local contact rate-limit cookies.
CONTACT_RATE_LIMIT_SECRET=

# Convex (written by `npx convex dev --once`; use cloud URLs after `npx convex login`)
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CONVEX_SITE_URL=
# Server-side HTTP action base. Same origin as NEXT_PUBLIC_CONVEX_SITE_URL.
CONVEX_SITE_URL=

# Shared secret for Next.js -> Convex HTTP contact ingress.
CONTACT_INGRESS_SECRET=

# Convex dashboard only — salt used before storing contact rate-limit IP hashes.
# RATE_LIMIT_SALT=
